# ============================================================
# CV Matcher — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# PostgreSQL connection string (required)
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/cv_matcher

# Groq API key for AI-powered CV parsing (free at console.groq.com)
GROQ_API_KEY=gsk_...

# Admin panel password (default: admin1234)
ADMIN_PASSWORD=admin1234

# Port for the API server (default: 8000)
PORT=8000

# Google OAuth Client ID — get from console.cloud.google.com
# Required for "Sign in with Google" on the candidate portal
GOOGLE_CLIENT_ID=
